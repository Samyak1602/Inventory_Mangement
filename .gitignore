# ========================
# Root .gitignore
# ========================

# Dependencies
node_modules/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ========================
# Frontend (Next.js)
# ========================
frontend/.next/
frontend/out/
frontend/build/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
frontend/coverage/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/.vercel

# ========================
# Backend (NestJS)
# ========================
backend/dist/
backend/coverage/
backend/*.tsbuildinfo

# SQLite database (don't push to GitHub)
backend/database.sqlite
*.sqlite
